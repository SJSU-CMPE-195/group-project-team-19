# ============================================================================
# .gitignore — CMPE 195 Group Project (C++/CMake + Python + UI)
# ============================================================================

# ------------------------------------
# Build artifacts & CMake generated
# ------------------------------------
build/
cmake-build-*/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile
*.o
*.obj
*.a
*.so
*.dylib
*.exe
*.out

# ------------------------------------
# Python virtual environments
# ------------------------------------
.venv*/
__pycache__/
*.pyc
*.pyo

# ------------------------------------
# IDE / Editor configs
# ------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.cache/
compile_commands.json

# ------------------------------------
# OS junk
# ------------------------------------
.DS_Store
Thumbs.db

# ------------------------------------
# UI build output (adjust if needed)
# ------------------------------------
ui/node_modules/
ui/dist/
ui/.next/

# ------------------------------------
# Docs build output
# ------------------------------------
docs/_build/
docs/html/

# ------------------------------------
# Misc
# ------------------------------------
*.log
*.tmp
